%% === Class Diagram ===
classDiagram
    class App {
        +BmsConnection[] bms
        +boolean autoRefresh
        +number autoRefreshInterval
        +init()
        +toggleAutoRefresh()
        +render()
        +updateDashboard()
        +drawChart(canvas, history)
    }

    class BmsConnection {
        +number index
        +BluetoothDevice device
        +BluetoothRemoteGATTServer server
        +BluetoothRemoteGATTService service
        +BluetoothRemoteGATTCharacteristic charNotify
        +BluetoothRemoteGATTCharacteristic charWrite
        +Uint8Array responseBuffer
        +number expectedLength
        +Function resolveResponse
        +boolean connected
        +VersionData versionData
        +BatteryData batteryData
        +DataPoint[] history
        +connect()
        +disconnect()
        +sendCommand(cmd) Uint8Array
        +fetchAll()
        +refresh()
        +pushHistory()
        +onNotification(event)
    }

    class VersionData {
        +string modelName
        +string firmwareVersion
        +string hardwareVersion
        +string serialNumber
        +string manufacturerDate
    }

    class BatteryData {
        +number packVoltage
        +number[] cellVoltages
        +number current
        +number[] temps
        +number soc
        +number soh
        +number cycleCount
        +number fullCapacity
        +number remainCapacity
        +number protectionStatus
        +boolean chargeEnabled
        +boolean dischargeEnabled
        +number balanceStatus
    }

    class CommandProtocol {
        <<constants>>
        +Uint8Array CMD_GET_VERSION
        +Uint8Array CMD_GET_BATTERY
        +number HEADER_BYTE
        +calculateCRC(data) number
        +validateResponse(data) boolean
    }

    class DataPoint {
        +number timestamp
        +number voltage
        +number current
        +number soc
        +number temp
    }

    class ChartRenderer {
        +drawChart(canvas, data)
        +drawLine(ctx, points, color, yMin, yMax)
        +drawAxis(ctx, label, min, max)
    }

    class BSIThemeBridge {
        <<portal integration>>
        +detectTheme()
        +onThemeChange(callback)
    }

    App "1" *-- "2" BmsConnection : manages dual batteries
    BmsConnection "1" *-- "1" VersionData : contains
    BmsConnection "1" *-- "1" BatteryData : contains
    BmsConnection "1" *-- "*" DataPoint : history
    App --> CommandProtocol : uses
    App --> ChartRenderer : uses
    App --> BSIThemeBridge : theme sync
    BmsConnection --> CommandProtocol : builds/validates commands


%% === Sequence Diagram — BLE Connection + Data Polling ===
sequenceDiagram
    participant User
    participant UI as App UI
    participant BMS as BmsConnection
    participant WB as Web Bluetooth API
    participant Dev as PQ BMS Device
    participant GATT as GATT Server
    participant CN as Char Notify
    participant CW as Char Write
    participant Parse as Parsers

    User->>UI: Click "Connect Battery 1"
    activate UI
    UI->>BMS: bms[0].connect()
    activate BMS

    BMS->>WB: navigator.bluetooth.requestDevice({filters, optionalServices})
    WB-->>User: Device picker dialog
    User->>WB: Select PQ BMS
    WB-->>BMS: BluetoothDevice

    BMS->>GATT: device.gatt.connect()
    activate GATT
    GATT-->>BMS: BluetoothRemoteGATTServer

    BMS->>GATT: server.getPrimaryService(serviceUUID)
    GATT-->>BMS: Service

    BMS->>GATT: service.getCharacteristic(notifyUUID)
    GATT-->>BMS: charNotify
    BMS->>GATT: service.getCharacteristic(writeUUID)
    GATT-->>BMS: charWrite

    BMS->>CN: charNotify.startNotifications()
    CN-->>BMS: Notifications enabled
    BMS->>CN: addEventListener("characteristicvaluechanged", onNotification)

    Note over BMS: Connection established

    BMS->>BMS: fetchAll()
    activate BMS

    Note over BMS: Step 1: Get Version

    BMS->>CW: sendCommand(CMD_GET_VERSION)
    BMS->>BMS: Create Promise, store resolveResponse
    CW->>Dev: Write version request + CRC

    loop Response assembly via notifications
        Dev-->>CN: Notification: response bytes
        CN-->>BMS: onNotification(event)
        BMS->>BMS: Append to responseBuffer
        BMS->>BMS: Calculate expectedLength from header

        alt Buffer complete (expectedLength reached)
            BMS->>BMS: validateResponse(buffer) -- check CRC
            alt CRC valid
                BMS->>BMS: resolveResponse(buffer)
            else CRC invalid
                BMS->>BMS: reject("CRC mismatch")
            end
        else Buffer incomplete
            Note over BMS: Wait for more notifications
        end
    end

    BMS->>Parse: parseVersionData(response)
    Parse-->>BMS: VersionData {model, firmware, serial, ...}
    Note over BMS: bms.versionData populated

    Note over BMS: Step 2: Get Battery Data

    BMS->>CW: sendCommand(CMD_GET_BATTERY)
    BMS->>BMS: Create Promise, store resolveResponse
    CW->>Dev: Write battery request + CRC

    loop Response assembly
        Dev-->>CN: Notification: battery response bytes
        CN-->>BMS: onNotification(event)
        BMS->>BMS: Append to responseBuffer
        alt Buffer complete
            BMS->>BMS: validateResponse + resolveResponse
        end
    end

    BMS->>Parse: parseBatteryData(response)
    Note over Parse: Extract: packVoltage, cellVoltages[],<br/>current, temps[], soc, soh, cycleCount,<br/>capacity, protectionStatus, balanceStatus
    Parse-->>BMS: BatteryData

    BMS->>BMS: pushHistory({timestamp, voltage, current, soc, temp})
    deactivate BMS

    BMS-->>UI: fetchAll() complete
    deactivate BMS
    deactivate GATT

    UI->>UI: updateDashboard()
    UI->>UI: drawChart(canvas, bms[0].history)
    UI-->>User: Display voltage, current, SOC, cells, temps
    deactivate UI

    Note over User,UI: Auto-refresh enabled

    User->>UI: Toggle auto-refresh ON
    activate UI

    loop Every 5 seconds
        UI->>BMS: bms[0].refresh()
        BMS->>CW: sendCommand(CMD_GET_BATTERY)
        CW->>Dev: Battery request
        Dev-->>CN: Battery response
        CN-->>BMS: onNotification (assembled)
        BMS->>Parse: parseBatteryData()
        Parse-->>BMS: Updated BatteryData
        BMS->>BMS: pushHistory()
        BMS-->>UI: refresh() complete
        UI->>UI: updateDashboard()
        UI->>UI: drawChart()
        UI-->>User: Updated display + chart
    end

    deactivate UI

    Note over Dev,UI: Disconnect scenario

    Dev-->>GATT: BLE disconnect
    GATT-->>BMS: gattserverdisconnected event
    BMS->>BMS: connected = false
    BMS-->>UI: Notify disconnected
    UI-->>User: Show disconnected status


