%% === State Diagram ===
stateDiagram-v2
    [*] --> Idle

    state Idle {
        [*] --> NoBatteries
        NoBatteries --> Battery1Only : Connect Battery 1
        NoBatteries --> Battery2Only : Connect Battery 2
        Battery1Only --> BothConnected : Connect Battery 2
        Battery2Only --> BothConnected : Connect Battery 1
    }

    state "Per-Battery State" as PerBattery {
        [*] --> BattDisconnected

        BattDisconnected --> BattConnecting : User clicks Connect

        state BattConnecting {
            [*] --> BLEPairing
            BLEPairing --> GATTConnect : Device selected
            GATTConnect --> ServiceDiscovery : Connected
            ServiceDiscovery --> CharSetup : Service found
            CharSetup --> NotifyEnabled : Chars discovered
            NotifyEnabled --> FetchingVersion : Notifications on
        }

        state BattConnected {
            [*] --> FetchingData

            state FetchingData {
                [*] --> SendingVersionCmd
                SendingVersionCmd --> AssemblingVersionResp : Command sent
                AssemblingVersionResp --> ParsingVersion : Response complete + CRC OK
                ParsingVersion --> SendingBatteryCmd : Version parsed
                SendingBatteryCmd --> AssemblingBatteryResp : Command sent
                AssemblingBatteryResp --> ParsingBattery : Response complete + CRC OK
                ParsingBattery --> DataReady : Battery data parsed
            }

            DataReady --> DisplayingData : Update UI
            DisplayingData --> WaitingRefresh : Render complete

            state WaitingRefresh {
                [*] --> ManualMode
                ManualMode --> AutoMode : Enable auto-refresh
                AutoMode --> ManualMode : Disable auto-refresh
            }

            AutoMode --> FetchingData : 5s interval tick
            ManualMode --> FetchingData : User clicks Refresh
        }

        FetchingVersion --> FetchingData : Ready
        BattConnecting --> BattDisconnected : Connection failed
        BattConnected --> BattDisconnected : BLE disconnect event
        BattConnected --> BattDisconnected : User disconnects
    }
